<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dark Mode Toggle</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f0e8;
      --surface: #ede8df;
      --text-primary: #1a1208;
      --text-secondary: #7a6e5e;
      --accent: #c9501c;
      --toggle-bg: #d4cec4;
      --toggle-knob: #1a1208;
      --card-bg: #fffdf8;
      --border: rgba(26,18,8,0.12);
      --shadow: rgba(26,18,8,0.15);
      --grain: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      transition: background 0.6s cubic-bezier(.4,0,.2,1), color 0.6s cubic-bezier(.4,0,.2,1);
    }

    [data-theme="dark"] {
      --bg: #0e0c0a;
      --surface: #171410;
      --text-primary: #f0ebe0;
      --text-secondary: #7a7268;
      --accent: #e8733a;
      --toggle-bg: #2a2520;
      --toggle-knob: #f0ebe0;
      --card-bg: #141210;
      --border: rgba(240,235,224,0.1);
      --shadow: rgba(0,0,0,0.5);
    }

    body {
      font-family: 'DM Mono', monospace;
      background: var(--bg);
      color: var(--text-primary);
      min-height: 100vh;
      display: grid;
      place-items: center;
      transition: background 0.6s cubic-bezier(.4,0,.2,1), color 0.6s cubic-bezier(.4,0,.2,1);
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: var(--grain);
      background-size: 200px 200px;
      pointer-events: none;
      z-index: 10;
      opacity: 0.6;
    }

    /* Ambient orbs */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.25;
      pointer-events: none;
      transition: background 0.8s ease, opacity 0.6s ease;
      animation: drift 12s ease-in-out infinite alternate;
    }
    .orb-1 {
      width: 500px; height: 500px;
      top: -100px; left: -100px;
      background: [data-theme="light"] ? #c9501c : #e8733a;
      background: var(--accent);
      animation-delay: 0s;
    }
    .orb-2 {
      width: 400px; height: 400px;
      bottom: -80px; right: -80px;
      background: #8b4513;
      animation-delay: -6s;
    }
    @keyframes drift {
      from { transform: translate(0,0) scale(1); }
      to { transform: translate(30px, 20px) scale(1.08); }
    }

    /* Main card */
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 2px;
      padding: 64px 72px;
      max-width: 560px;
      width: calc(100% - 48px);
      box-shadow: 0 24px 64px var(--shadow), 0 2px 8px var(--shadow);
      position: relative;
      z-index: 1;
      transition: background 0.6s cubic-bezier(.4,0,.2,1), box-shadow 0.6s ease, border-color 0.6s ease;
    }

    .eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
      transition: color 0.6s ease;
    }

    h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.4rem, 5vw, 3.2rem);
      line-height: 1.05;
      color: var(--text-primary);
      margin-bottom: 8px;
      transition: color 0.6s ease;
    }

    h1 em {
      font-style: italic;
      color: var(--accent);
      transition: color 0.6s ease;
    }

    .subtitle {
      font-size: 11px;
      color: var(--text-secondary);
      letter-spacing: 0.05em;
      line-height: 1.6;
      margin-bottom: 48px;
      transition: color 0.6s ease;
    }

    /* Toggle */
    .toggle-section {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 48px;
    }

    .toggle-label {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-secondary);
      transition: color 0.6s ease;
      flex: 1;
    }

    .toggle-wrap {
      position: relative;
    }

    .toggle-input {
      position: absolute;
      opacity: 0;
      width: 0; height: 0;
    }

    .toggle-track {
      display: flex;
      align-items: center;
      width: 72px;
      height: 36px;
      background: var(--toggle-bg);
      border-radius: 0;
      border: 1px solid var(--border);
      cursor: pointer;
      position: relative;
      transition: background 0.4s ease, border-color 0.4s ease;
    }

    .toggle-track::after {
      content: '';
      position: absolute;
      left: 4px;
      width: 26px;
      height: 26px;
      background: var(--toggle-knob);
      border-radius: 0;
      transition: transform 0.4s cubic-bezier(.4,0,.2,1), background 0.4s ease;
    }

    .toggle-input:checked + .toggle-track::after {
      transform: translateX(36px);
    }

    .toggle-input:focus-visible + .toggle-track {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }

    .icon-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--text-secondary);
      transition: color 0.4s ease;
    }
    .icon-sun, .icon-moon {
      font-size: 15px;
      transition: transform 0.5s cubic-bezier(.4,0,.2,1), opacity 0.4s ease;
    }

    /* Status badge */
    .status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-secondary);
      padding: 8px 14px;
      border: 1px solid var(--border);
      border-radius: 0;
      transition: all 0.4s ease;
      margin-bottom: 40px;
    }

    .status-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    /* Divider */
    .divider {
      width: 100%;
      height: 1px;
      background: var(--border);
      margin-bottom: 28px;
      transition: background 0.6s ease;
    }

    /* Feature rows */
    .feature {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      letter-spacing: 0.06em;
      color: var(--text-secondary);
      transition: color 0.6s ease, border-color 0.6s ease;
    }
    .feature:last-child { border-bottom: none; }
    .feature strong {
      color: var(--text-primary);
      font-weight: 500;
      transition: color 0.6s ease;
    }
    .feature-val {
      font-family: 'DM Mono', monospace;
      color: var(--accent);
      font-size: 10px;
      transition: color 0.6s ease;
    }

    /* Corner accent */
    .card::before {
      content: '';
      position: absolute;
      top: -1px; left: -1px;
      width: 32px; height: 32px;
      border-top: 2px solid var(--accent);
      border-left: 2px solid var(--accent);
      transition: border-color 0.6s ease;
    }
    .card::after {
      content: '';
      position: absolute;
      bottom: -1px; right: -1px;
      width: 32px; height: 32px;
      border-bottom: 2px solid var(--accent);
      border-right: 2px solid var(--accent);
      transition: border-color 0.6s ease;
    }
  </style>
</head>
<body>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="card">
    <p class="eyebrow">Interface Settings</p>
    <h1>Toggle<br/><em>Dark Mode</em></h1>
    <p class="subtitle">Switch between light and dark themes.<br/>Your preference is applied instantly.</p>

    <div class="toggle-section">
      <span class="toggle-label" id="mode-label">Light Mode</span>
      <div class="icon-row">
        <span class="icon-sun">☀</span>
        <div class="toggle-wrap">
          <input type="checkbox" class="toggle-input" id="darkToggle" role="switch" aria-label="Toggle dark mode"/>
          <label class="toggle-track" for="darkToggle"></label>
        </div>
        <span class="icon-moon">☽</span>
      </div>
    </div>

    <div class="status">
      <span class="status-dot"></span>
      <span id="status-text">Light theme active</span>
    </div>

    <div class="divider"></div>

    <div class="feature">
      <strong>Current Theme</strong>
      <span class="feature-val" id="theme-val">LIGHT</span>
    </div>
    <div class="feature">
      <strong>Background</strong>
      <span class="feature-val" id="bg-val">#f5f0e8</span>
    </div>
    <div class="feature">
      <strong>Transition</strong>
      <span class="feature-val">600ms ease</span>
    </div>
    <div class="feature">
      <strong>System Pref</strong>
      <span class="feature-val" id="sys-val">—</span>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('darkToggle');
    const html = document.documentElement;
    const modeLabel = document.getElementById('mode-label');
    const statusText = document.getElementById('status-text');
    const themeVal = document.getElementById('theme-val');
    const bgVal = document.getElementById('bg-val');
    const sysVal = document.getElementById('sys-val');

    // Detect system preference
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
    sysVal.textContent = prefersDark.matches ? 'DARK' : 'LIGHT';

    function applyTheme(dark) {
      html.setAttribute('data-theme', dark ? 'dark' : 'light');
      modeLabel.textContent = dark ? 'Dark Mode' : 'Light Mode';
      statusText.textContent = dark ? 'Dark theme active' : 'Light theme active';
      themeVal.textContent = dark ? 'DARK' : 'LIGHT';
      bgVal.textContent = dark ? '#0e0c0a' : '#f5f0e8';
    }

    toggle.addEventListener('change', () => applyTheme(toggle.checked));

    // Keyboard shortcut: D
    document.addEventListener('keydown', (e) => {
      if (e.key === 'd' || e.key === 'D') {
        toggle.checked = !toggle.checked;
        applyTheme(toggle.checked);
      }
    });
  </script>
</body>
</html>
